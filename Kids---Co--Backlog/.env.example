# API Configuration (used at build time on Vercel)
# Production – لازم تكون دي على مشروع Vercel (kids-co-backlog) عشان الموقع يشتغل:
VITE_API_URL=https://tovo-b.developteam.site/kids/api
VITE_API_HOST=https://tovo-b.developteam.site/kids

# Local only – استخدم لو بتشغل الفرونت محلي ضد الباكند على جهازك:
# VITE_API_URL=http://localhost:5000/api
# VITE_API_HOST=http://localhost:5000
