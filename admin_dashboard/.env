# ==========================================================
# Kids & Co Admin Dashboard - Environment Variables
# ==========================================================
# Vite reads only variables prefixed with VITE_ at build time.
# ==========================================================

# ----------------------------------------------------------
# API Configuration
# ----------------------------------------------------------
# Production backend (kids.nodeteam.site)
VITE_API_URL=https://kids.nodeteam.site/api
VITE_API_HOST=https://kids.nodeteam.site

# Production server – uncomment to connect directly to tovo-b:
# VITE_API_URL=https://tovo-b.developteam.site/kids/api
# VITE_API_HOST=https://tovo-b.developteam.site/kids

# Local backend (no proxy):
# VITE_API_URL=http://localhost:5000/api
# VITE_API_HOST=http://localhost:5000

# ----------------------------------------------------------
# Dev proxy target (used by vite.config.js -> server.proxy)
# ----------------------------------------------------------
VITE_PROXY_TARGET=https://kids.nodeteam.site
